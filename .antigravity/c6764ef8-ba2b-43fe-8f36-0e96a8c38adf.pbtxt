    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport SpotifyPrototype from \'./components/SpotifyPrototype\';\nimport ReviewConsole from \'./components/ReviewConsole\';\nimport { FlowType } from \'./types\';\nimport { Music, Radio, Sparkles, Award, FileSpreadsheet, List, FileText } from \'lucide-react\';\n\nexport default function App() {\n  const [currentFlow, setCurrentFlow] = useState<FlowType>(\'revised\');\n  const [logs, setLogs] = useState<{ timestamp: string; action: string; detail: string }[]>([]);\n\n  // Function to bridge live events from the player simulation into the review telemetry logger\n  const handleTrackAction = (action: string, detail: string) => {\n    const time = new Date().toLocaleTimeString([], { hour: \'2-digit\', minute: \'2-digit\', second: \'2-digit\' });\n    setLogs(prev => [\n      { timestamp: time, action, detail },\n      ...prev.slice(0, 49) // hold up to 50 logs for scroll performance\n    ]);\n  };\n\n  const handleClearLogs = () => {\n    setLogs([]);\n  };\n\n  return (\n    <div className=\"min-h-screen bg-[#080808] text-white flex flex-col font-sans select-none antialiased selection:bg-spotify-green selection:text-black\">\n      \n      {/* GLOBAL HEADER BAR */}\n      <header className=\"bg-spotify-black/80 border-b border-white/5 py-4 px-6 sticky top-0 backdrop-blur-md z-40 shrink-0\">\n        <div className=\"max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4\">\n          \n          <div className=\"flex items-center gap-3\">\n            <div className=\"w-10 h-10 bg-spotify-green rounded-xl flex items-center justify-center text-spotify-black\">\n              <Radio className=\"w-5.5 h-5.5\" />\n            </div>\n            <div>\n              <div className=\"flex items-center gap-2\">\n                <span className=\"text-white font-extrabold text-sm tracking-tight\">Spotify Discovery Boost</span>\n                <span className=\"px-2 py-0.5 bg-spotify-green/10 text-spotify-green text-[9px] font-black tracking-widest rounded-full uppercase\">\n                  V2 Prototype\n                </span>\n              </div>\n              <p className=\"text-xs text-spotify-gray mt-0.5\">PM & UX Evaluation Playground</p>\n            </div>\n          </div>\n\n          {/* Quick Stats Banner */}\n          <div className=\"hidden lg:flex items-center gap-6 text-xs text-spotify-gray border-l border-white/10 pl-6\">\n            <div>\n              <span className=\"block text-[10px] uppercase font-black tracking-wider text-spotify-green\">Personalization Zone</span>\n              <p className=\"text-white font-bold mt-0.5\">Subtle Synth & Indie Vibe</p>\n            </div>\n            <div>\n              <span className=\"block text-[10px] uppercase font-black tracking-wider text-spotify-green\">Session Status</span>\n              <p className=\"text-white font-bold mt-0.5\">Awaiting Boost Blend</p>\n            </div>\n          </div>\n\n          {/* Global Flow Toggle Control */}\n          <div className=\"flex bg-spotify-card p-1 rounded-full border border-white/5 shadow-inner shrink-0\">\n            <button \n              onClick={() => setCurrentFlow(\'original\')}\n              className={`px-4 py-2 rounded-full text-xs font-black transition-all ${currentFlow === \'original\' ? \'bg-red-500/10 text-red-400 border border-red-500/20 shadow-md\' : \'text-spotify-gray hover:text-white\'}`}\n            >\n              RAW ORIGINAL\n            </button>\n            <button \n              onClick={() => setCurrentFlow(\'revised\')}\n              className={`px-4 py-2 rounded-full text-xs font-black transition-all ${currentFlow === \'revised\' ? \'bg-spotify-green text-spotify-black font-extrabold shadow-md\' : \'text-spotify-gray hover:text-white\'}`}\n            >\n              REVISED UX\n            </button>\n          </div>\n\n        </div>\n      </header>\n\n      {/* DASHBOARD LAYOUT GRID */}\n      <main className=\"flex-1 max-w-7xl w-full mx-auto p-4 md:p-6 lg:p-8 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start\">\n        \n        {/* LEFT COLUMN: CONTEXT GUIDE & INTERACTIVE PLAYER */}\n        <section className=\"lg:col-span-5 xl:col-span-4 flex flex-col gap-6 w-full items-center\">\n          \n          {/* Quick Instructions Bubble */}\n          <div className=\"w-full bg-spotify-surface/40 p-4 border border-white/5 rounded-2xl text-xs text-spotify-gray\">\n            <div className=\"flex items-center gap-2 mb-2 text-white font-bold\">\n              <Sparkles className=\"w-4 h-4 text-spotify-green\" />\n              <span>How to play with this sandbox:</span>\n            </div>\n            <ul className=\"list-decimal pl-4 space-y-1 mt-1 leading-normal\">\n              <li>Wait 4 seconds or tap <strong>&quot;Refresh Music&quot;</strong> in the toolbar to trigger the Discovery Boost prompt.</li>\n              <li>Observe how the <strong>Original Alert modal</strong> compares with the <strong>Sleek Onboarding slider</strong>.</li>\n              <li>Open the <strong>Queue</strong> view (top-right icon) to see the recommendation reasons and inline tuning buttons.</li>\n              <li>Liking a discovery track on Revised mode triggers a vector <strong>Heart Burst</strong> success celebration!</li>\n            </ul>\n          </div>\n\n          {/* Device Mockup Frame */}\n          <div className=\"w-full\">\n            <SpotifyPrototype \n              currentFlow={currentFlow} \n              onChangeFlow={setCurrentFlow} \n              onTrackAction={handleTrackAction}\n            />\n          </div>\n\n        </section>\n\n        {/* RIGHT COLUMN: SENIOR PM & UX AUDIT CONSOLE */}\n        <section className=\"lg:col-span-7 xl:col-span-8 h-full min-h-[600px] lg:h-[780px] w-full flex flex-col\">\n          <ReviewConsole \n            currentFlow={currentFlow} \n            onChangeFlow={setCurrentFlow} \n            logs={logs}\n            onClearLogs={handleClearLogs}\n          />\n        </section>\n\n      </main>\n\n      {/* STATIC OUT-OF-IFRAME COMPLIANT APP CREDENTIAL FOOTER */}\n      <footer className=\"bg-spotify-black/40 border-t border-white/5 py-3 px-6 text-center text-[10px] text-spotify-dark-gray mt-auto shrink-0\">\n        <div className=\"max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2\">\n          <span>Spotify Discovery Boost evaluation mockup. For evaluation purposes only. No affiliation with Spotify AB.</span>\n          <span>Designed under Lead PM & UX Core Specifications \342\200\242 June 2026</span>\n        </div>\n      </footer>\n\n    </div>\n  );\n}\n"
    }
