    instruction: "Inject annotation pins and uppercase bold text-display style to Strategic Review section"
    replacement_infos {
      original_chunk {
        target_content: "            {/* Critique sections */}\n            <div className=\"space-y-4\">\n              <div className=\"border border-white/5 rounded-2xl p-4 bg-spotify-surface/30\">\n                <div className=\"flex items-center justify-between mb-3\">\n                  <span className=\"text-xs font-black text-white uppercase tracking-wider\">Is it a \"Student Project\" or \"Spotify Feature\"?</span>\n                  <span className=\"px-2.5 py-1 bg-red-500/10 border border-red-500/20 text-red-400 text-[10px] font-extrabold rounded\">STUDENT PROJECT MARK</span>\n                </div>\n                <p className=\"text-xs leading-normal\">\n                  In its current raw state, it behaves like a **student concept**. Spotify features are designed to be extremely quiet. The original design uses disruptive modal alerts (which Spotify hasn\'t used for core functions in half a decade) and breaks the \"Queue Sovereignty\" rule (the concept that a user\'s active play queue is holy ground that should never be modified without clear permission and visibility).\n                </p>\n                <div className=\"mt-3 p-3 bg-white/5 rounded-xl text-xs text-spotify-gray\">\n                  <strong>PM Fix:</strong> Ensure the user initiates the queue blending explicitly (Pull model). This turns automated payload injection into an active consent gesture.\n                </div>\n              </div>\n\n              {/* Specific PM critique items */}\n              {CRITIQUE_SECTIONS.slice(0, 2).map(item => (\n                <div key={item.id} className=\"border border-white/5 rounded-2xl p-4 bg-spotify-surface/10 space-y-3\">\n                  <div className=\"flex justify-between items-center\">\n                    <h4 className=\"text-xs font-black text-white uppercase tracking-wider\">{item.title}</h4>\n                    <span className={`px-2 py-0.5 text-[9px] font-black rounded uppercase ${\n                      item.rating === \'critical\' ? \'bg-red-500/10 text-red-400 border border-red-500/20\' : \'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20\'\n                    }`}>\n                      {item.rating.toUpperCase()} SEVERITY\n                    </span>\n                  </div>\n                  <p className=\"text-xs text-spotify-gray\">{item.description}</p>\n                  <div className=\"bg-black/25 p-3 rounded-xl\">\n                    <p className=\"text-xs text-white/90 font-medium\">Teardown Analysis:</p>\n                    <p className=\"text-[11px] text-spotify-gray mt-1 leading-normal\">{item.analysis}</p>\n                  </div>\n                  <div className=\"bg-spotify-green/5 p-3 rounded-xl border border-spotify-green/10\">\n                    <p className=\"text-xs text-spotify-green font-bold\">Recommended Pivot Solution:</p>\n                    <p className=\"text-[11px] text-spotify-gray mt-1 leading-normal\">{item.recommendation}</p>\n                  </div>\n                </div>\n              ))}\n            </div>"
        replacement_content: "            {/* Critique sections */}\n            <div className=\"space-y-4\">\n              <div className=\"border border-white/5 rounded-2xl p-5 bg-spotify-surface/30 relative overflow-hidden\">\n                <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-3\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"annotation-pin shrink-0\">A</span>\n                    <span className=\"text-sm font-black text-white uppercase tracking-tight text-display italic\">Student Project vs. Spotify Feature</span>\n                  </div>\n                  <span className=\"px-2.5 py-1 bg-red-500/10 border border-red-500/20 text-red-400 text-[10px] font-extrabold rounded self-start sm:self-auto\">STUDENT CONCEPT MARK</span>\n                </div>\n                <p className=\"text-xs leading-normal\">\n                  In its current raw state, it behaves like a **student concept**. Spotify features are designed to be extremely quiet. The original design uses disruptive modal alerts (which Spotify hasn\'t used for core functions in half a decade) and breaks the \"Queue Sovereignty\" rule (the concept that a user\'s active play queue is holy ground that should never be modified without clear permission and visibility).\n                </p>\n                <div className=\"mt-3 p-3 bg-white/5 rounded-xl text-xs text-spotify-gray\">\n                  <strong>PM Fix:</strong> Ensure the user initiates the queue blending explicitly (Pull model). This turns automated payload injection into an active consent gesture.\n                </div>\n              </div>\n\n              {/* Specific PM critique items */}\n              {CRITIQUE_SECTIONS.slice(0, 2).map((item, index) => (\n                <div key={item.id} className=\"border border-white/5 rounded-2xl p-5 bg-spotify-surface/10 space-y-3 relative\">\n                  <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-2\">\n                    <div className=\"flex items-center gap-2\">\n                      <span className=\"annotation-pin shrink-0 bg-neutral-800 text-spotify-green font-mono\">{index + 1}</span>\n                      <h4 className=\"text-sm font-black text-white uppercase tracking-tight text-display italic\">{item.title}</h4>\n                    </div>\n                    <span className={`px-2 py-0.5 text-[9px] font-black rounded uppercase self-start sm:self-auto ${\n                      item.rating === \'critical\' ? \'bg-red-500/10 text-red-400 border border-red-500/20\' : \'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20\'\n                    }`}>\n                      {item.rating.toUpperCase()} SEVERITY\n                    </span>\n                  </div>\n                  <p className=\"text-xs text-spotify-gray\">{item.description}</p>\n                  <div className=\"bg-black/25 p-3 rounded-xl\">\n                    <p className=\"text-xs text-white/90 font-medium\">Teardown Analysis:</p>\n                    <p className=\"text-[11px] text-spotify-gray mt-1 leading-normal\">{item.analysis}</p>\n                  </div>\n                  <div className=\"bg-spotify-green/5 p-3 rounded-xl border border-spotify-green/10\">\n                    <p className=\"text-xs text-spotify-green font-bold\">Recommended Pivot Solution:</p>\n                    <p className=\"text-[11px] text-spotify-gray mt-1 leading-normal\">{item.recommendation}</p>\n                  </div>\n                </div>\n              ))}\n            </div>"
      }
