          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const parts = durationStr.split(\':\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const totalSeconds = parseInt(parts[0]) * 60 + parts[1] ? parseInt(parts[1]) : 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const currentSeconds = Math.floor((percentage / 100) * totalSeconds);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const m = Math.floor(currentSeconds / 60);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const s = currentSeconds % 60;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return `${m}:${s < 10 ? \'0\' : \'\'}${s}`;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
