    instruction: "Enhance the UX weaknesses section with text-display styling and annotation markers"
    replacement_infos {
      original_chunk {
        target_content: "            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n              <div className=\"p-4 bg-red-500/5 border border-red-500/10 rounded-2xl\">\n                <span className=\"text-xs font-bold text-red-400 uppercase tracking-widest block mb-2\">1. The Interrupt</span>\n                <p className=\"text-[11.5px] leading-relaxed\">\n                  Interrupting a track playback with a full prompt forces a jarring visual context switch, often irritating focus-oriented listeners.\n                </p>\n                <div className=\"mt-3 text-[10px] text-spotify-gray uppercase tracking-widest\">Original Rating: <strong>FAIL</strong></div>\n              </div>\n\n              <div className=\"p-4 bg-yellow-500/5 border border-yellow-500/10 rounded-2xl\">\n                <span className=\"text-xs font-bold text-yellow-400 uppercase tracking-widest block mb-2\">2. Queue Mystery</span>\n                <p className=\"text-[11.5px] leading-relaxed\">\n                  Inserting recommendations without showing placement intervals or seed references induces \"fear of the unknown queue.\"\n                </p>\n                <div className=\"mt-3 text-[10px] text-spotify-gray uppercase tracking-widest\">Original Rating: <strong>FAIL</strong></div>\n              </div>\n\n              <div className=\"p-4 bg-green-500/5 border border-green-500/10 rounded-2xl\">\n                <span className=\"text-xs font-bold text-spotify-green uppercase tracking-widest block mb-2\">3. Feedback Void</span>\n                <p className=\"text-[11.5px] leading-relaxed\">\n                  No quick way to reject a bad match without searching, forcing listeners to skip manually, which trains the algorithm incorrectly.\n                </p>\n                <div className=\"mt-3 text-[10px] text-spotify-gray uppercase tracking-widest\">Original Rating: <strong>FAIL</strong></div>\n              </div>\n            </div>\n\n            {/* In depth detail sections */}\n            <div className=\"space-y-4\">\n              <div className=\"border border-white/5 rounded-2xl p-4 bg-spotify-surface/30\">\n                <h4 className=\"text-xs font-black text-white uppercase tracking-wider mb-2\">Architecting Trust through Rationale</h4>\n                <p className=\"text-xs leading-normal\">\n                  Our revised design implements **Contextual Explanation Badges** (e.g. *\"Inspired by Midnight City\"*). When a user knows *why* a song is playing, they are 3.4x more likely to listen past the first 30 seconds rather than skipping instantly, directly boosting algorithmic feedback loops.\n                </p>\n                \n                {/* Visual example list */}\n                <div className=\"mt-4 p-3 bg-black/40 rounded-xl space-y-2 border border-white/5\">\n                  <div className=\"flex justify-between items-center text-[11px]\">\n                    <span className=\"text-spotify-gray font-mono\">Simulated Seed Song:</span>\n                    <span className=\"text-white font-bold\">Midnight City (M83)</span>\n                  </div>\n                  <div className=\"h-px bg-white/5\"></div>\n                  <div className=\"flex justify-between items-center text-[11px]\">\n                    <span className=\"text-spotify-gray font-mono\">Discovered Track:</span>\n                    <span className=\"text-spotify-green font-bold\">Neon Dreams (Kavinsky)</span>\n                  </div>\n                  <div className=\"h-px bg-white/5\"></div>\n                  <div className=\"flex justify-between items-center text-[11px]\">\n                    <span className=\"text-spotify-gray font-mono\">Rendered Rationale Capsule:</span>\n                    <span className=\"px-2 py-0.5 bg-spotify-green/10 text-spotify-green rounded text-[9px] font-bold uppercase tracking-wider\">\n                      Inspired by your love for M83\n                    </span>\n                  </div>\n                </div>\n              </div>"
        replacement_content: "            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n              <div className=\"p-4 bg-red-500/5 border border-red-500/10 rounded-2xl relative overflow-hidden\">\n                <div className=\"flex items-center gap-2 mb-2\">\n                  <span className=\"annotation-pin shrink-0 bg-red-500 text-white font-mono font-black\">!</span>\n                  <span className=\"text-xs font-black text-red-400 uppercase tracking-tight text-display italic\">1. The Interrupt</span>\n                </div>\n                <p className=\"text-[11.5px] leading-relaxed text-spotify-gray\">\n                  Interrupting a track playback with a full prompt forces a jarring visual context switch, often irritating focus-oriented listeners.\n                </p>\n                <div className=\"mt-3 text-[10px] text-red-400 uppercase tracking-widest font-black\">Original Rating: FAIL</div>\n              </div>\n\n              <div className=\"p-4 bg-yellow-500/5 border border-yellow-500/10 rounded-2xl relative overflow-hidden\">\n                <div className=\"flex items-center gap-2 mb-2\">\n                  <span className=\"annotation-pin shrink-0 bg-yellow-500 text-black font-mono font-black\">?</span>\n                  <span className=\"text-xs font-black text-yellow-400 uppercase tracking-tight text-display italic\">2. Queue Mystery</span>\n                </div>\n                <p className=\"text-[11.5px] leading-relaxed text-spotify-gray\">\n                  Inserting recommendations without showing placement intervals or seed references induces \"fear of the unknown queue.\"\n                </p>\n                <div className=\"mt-3 text-[10px] text-yellow-400 uppercase tracking-widest font-black\">Original Rating: FAIL</div>\n              </div>\n\n              <div className=\"p-4 bg-red-500/5 border border-red-500/10 rounded-2xl relative overflow-hidden\">\n                <div className=\"flex items-center gap-2 mb-2\">\n                  <span className=\"annotation-pin shrink-0 bg-red-500 text-white font-mono font-black\">x</span>\n                  <span className=\"text-xs font-black text-spotify-green uppercase tracking-tight text-display italic\">3. Feedback Void</span>\n                </div>\n                <p className=\"text-[11.5px] leading-relaxed text-spotify-gray\">\n                  No quick way to reject a bad match without searching, forcing listeners to skip manually, which trains the algorithm incorrectly.\n                </p>\n                <div className=\"mt-3 text-[10px] text-red-400 uppercase tracking-widest font-black\">Original Rating: FAIL</div>\n              </div>\n            </div>\n\n            {/* In depth detail sections */}\n            <div className=\"space-y-4\">\n              <div className=\"border border-white/5 rounded-2xl p-5 bg-spotify-surface/30 relative overflow-hidden\">\n                <div className=\"flex items-center gap-2 mb-3\">\n                  <span className=\"annotation-pin shrink-0 bg-spotify-green text-black\">B</span>\n                  <h4 className=\"text-sm font-black text-white uppercase tracking-tight text-display italic\">Architecting Trust through Rationale</h4>\n                </div>\n                <p className=\"text-xs leading-normal\">\n                  Our revised design implements **Contextual Explanation Badges** (e.g. *\"Inspired by Midnight City\"*). When a user knows *why* a song is playing, they are 3.4x more likely to listen past the first 30 seconds rather than skipping instantly, directly boosting algorithmic feedback loops.\n                </p>\n                \n                {/* Visual example list */}\n                <div className=\"mt-4 p-3 bg-black/40 rounded-xl space-y-2 border border-white/5\">\n                  <div className=\"flex justify-between items-center text-[11px]\">\n                    <span className=\"text-spotify-gray font-mono\">Simulated Seed Song:</span>\n                    <span className=\"text-white font-bold\">Midnight City (M83)</span>\n                  </div>\n                  <div className=\"h-px bg-white/5\"></div>\n                  <div className=\"flex justify-between items-center text-[11px]\">\n                    <span className=\"text-spotify-gray font-mono\">Discovered Track:</span>\n                    <span className=\"text-spotify-green font-bold\">Neon Dreams (Kavinsky)</span>\n                  </div>\n                  <div className=\"h-px bg-white/5\"></div>\n                  <div className=\"flex justify-between items-center text-[11px]\">\n                    <span className=\"text-spotify-gray font-mono\">Rendered Rationale Capsule:</span>\n                    <span className=\"px-2 py-0.5 bg-spotify-green/10 text-spotify-green rounded text-[9px] font-bold uppercase tracking-wider\">\n                      Inspired by your love for M83\n                    </span>\n                  </div>\n                </div>\n              </div>"
      }
      num_matches: 1
    }
  }
}
