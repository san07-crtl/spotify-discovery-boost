      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, sans-serif;\n  --font-mono: \"JetBrains Mono\", ui-monospace, SFMono-Regular, monospace;\n  --color-spotify-green: #1DB954;\n  --color-spotify-green-hover: #1ED760;\n  --color-spotify-black: #000000;\n  --color-spotify-dark: #121212;\n  --color-spotify-surface: #181818;\n  --color-spotify-card: #282828;\n  --color-spotify-hover: #333333;\n  --color-spotify-gray: #b3b3b3;\n  --color-spotify-dark-gray: #535353;\n}\n\n/* Custom radial background gradient */\n.spotify-gradient {\n  background: radial-gradient(circle at 80% 20%, rgba(29, 185, 84, 0.16) 0%, transparent 60%),\n              radial-gradient(circle at 20% 80%, #121212 0%, #050505 100%);\n}\n\n/* Glass panel design matching the theme */\n.glass-panel {\n  background: rgba(255, 255, 255, 0.03);\n  border: 1px solid rgba(255, 255, 255, 0.08);\n  backdrop-filter: blur(16px);\n}\n\n/* Bold Typography display-focused rules */\n.text-display {\n  font-family: \"Inter\", sans-serif;\n  letter-spacing: -0.04em;\n  line-height: 0.95;\n}\n\n/* Design annotation marker styles */\n.annotation-pin {\n  width: 20px;\n  height: 20px;\n  background: #1DB954;\n  color: black;\n  font-weight: 900;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 0 12px rgba(29, 185, 84, 0.5);\n  font-size: 11px;\n}\n\n/* Custom scrollbar behaviors for clean UI lists */\n.custom-scrollbar::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n\n.custom-scrollbar::-webkit-scrollbar-track {\n  background: rgba(0, 0, 0, 0.2);\n}\n\n.custom-scrollbar::-webkit-scrollbar-thumb {\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 3px;\n}\n\n.custom-scrollbar::-webkit-scrollbar-thumb:hover {\n  background: rgba(255, 255, 255, 0.25);\n}\n"
