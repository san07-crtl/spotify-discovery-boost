      replacement_content: "import React, { useState } from \'react\';\nimport { \n  FileText, AlertTriangle, ShieldCheck, BarChart3, ArrowRightLeft, \n  Terminal, CheckCircle, XCircle, ChevronRight, RefreshCw, Star, Info, ListTodo, Award, HelpCircle\n} from \'lucide-react\';\nimport { CritiqueItem, MetricCard, FlowType } from \'../types\';\nimport { CRITIQUE_SECTIONS, MICROCOPY_COMPARISON, METRICS_BOARD, FLOW_STEPS } from \'../data/critique\';\n\ninterface ReviewConsoleProps {\n  currentFlow: FlowType;\n  onChangeFlow: (flow: FlowType) => void;\n  logs: { timestamp: string; action: string; detail: string }[];\n  onClearLogs: () => void;\n}\n\nexport default function ReviewConsole({ currentFlow, onChangeFlow, logs, onClearLogs }: ReviewConsoleProps) {\n  const [activeTab, setActiveTab] = useState<\'pm\' | \'ux\' | \'copy\' | \'metrics\' | \'flow\'>(\'pm\');\n\n  return (\n    <div className=\"flex flex-col h-full bg-spotify-dark border border-white/5 rounded-3xl overflow-hidden shadow-2xl\">\n      \n      {/* PM CONSOLE HEADER */}\n      <div className=\"bg-spotify-surface/80 p-5 border-b border-white/5 flex flex-col md:flex-row justify-between md:items-center gap-4\">\n        <div>\n          <div className=\"flex items-center gap-2\">\n            <span className=\"px-2 py-0.5 bg-spotify-green/10 text-spotify-green text-[10px] font-black tracking-widest rounded uppercase\">\n              Product teardown\n            </span>\n            <span className=\"text-white/40 text-xs font-mono\">\342\200\242 Lead PM & UX Audit</span>\n          </div>\n          <h2 className=\"text-xl font-black text-white tracking-tight mt-1\">Discovery Boost Teardown</h2>\n        </div>\n\n        {/* Global flow selector tab */}\n        <div className=\"flex bg-black/40 p-1 rounded-xl border border-white/5 self-start md:self-auto\">\n          <button \n            onClick={() => onChangeFlow(\'original\')}\n            className={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${currentFlow === \'original\' ? \'bg-red-500/10 text-red-400 border border-red-500/20\' : \'text-spotify-gray hover:text-white\'}`}\n          >\n            <AlertTriangle className=\"w-3.5 h-3.5\" />\n            Original Raw Mockup\n          </button>\n          <button \n            onClick={() => onChangeFlow(\'revised\')}\n            className={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${currentFlow === \'revised\' ? \'bg-spotify-green/10 text-spotify-green border border-spotify-green/25\' : \'text-spotify-gray hover:text-white\'}`}\n          >\n            <CheckCircle className=\"w-3.5 h-3.5\" />\n            Revised UX Flow\n          </button>\n        </div>\n      </div>\n\n      {/* RECONSTRUCTED TAB SYSTEM */}\n      <div className=\"flex border-b border-white/5 bg-spotify-surface/40 overflow-x-auto custom-scrollbar\">\n        <button \n          onClick={() => setActiveTab(\'pm\')}\n          className={`flex items-center gap-2 px-5 py-3.5 text-xs font-bold shrink-0 transition-all border-b-2 ${activeTab === \'pm\' ? \'text-spotify-green border-spotify-green\' : \'text-spotify-gray hover:text-white border-transparent\'}`}\n        >\n          <Award className=\"w-4 h-4\" />\n          1. Strategic Review\n        </button>\n        <button \n          onClick={() => setActiveTab(\'ux\')}\n          className={`flex items-center gap-2 px-5 py-3.5 text-xs font-bold shrink-0 transition-all border-b-2 ${activeTab === \'ux\' ? \'text-spotify-green border-spotify-green\' : \'text-spotify-gray hover:text-white border-transparent\'}`}\n        >\n          <AlertTriangle className=\"w-4 h-4\" />\n          2. UX Friction & Trust\n        </button>\n        <button \n          onClick={() => setActiveTab(\'copy\')}\n          className={`flex items-center gap-2 px-5 py-3.5 text-xs font-bold shrink-0 transition-all border-b-2 ${activeTab === \'copy\' ? \'text-spotify-green border-spotify-green\' : \'text-spotify-gray hover:text-white border-transparent\'}`}\n        >\n          <FileText className=\"w-4 h-4\" />\n          3. Copy & Onboarding\n        </button>\n        <button \n          onClick={() => setActiveTab(\'metrics\')}\n          className={`flex items-center gap-2 px-5 py-3.5 text-xs font-bold shrink-0 transition-all border-b-2 ${activeTab === \'metrics\' ? \'text-spotify-green border-spotify-green\' : \'text-spotify-gray hover:text-white border-transparent\'}`}\n        >\n          <BarChart3 className=\"w-4 h-4\" />\n          4. Performance KPIs\n        </button>\n        <button \n          onClick={() => setActiveTab(\'flow\')}\n          className={`flex items-center gap-2 px-5 py-3.5 text-xs font-bold shrink-0 transition-all border-b-2 ${activeTab === \'flow\' ? \'text-spotify-green border-spotify-green\' : \'text-spotify-gray hover:text-white border-transparent\'}`}\n        >\n          <ArrowRightLeft className=\"w-4 h-4\" />\n          5. Production Blueprint\n        </button>\n      </div>\n\n      {/* TAB CONTENT GRID */}\n      <div className=\"flex-1 overflow-y-auto p-6 space-y-6 custom-scrollbar text-sm leading-relaxed text-spotify-gray\">\n        \n        {/* TAB 1: STRATEGIC PM VERDICT */}\n        {activeTab === \'pm\' && (\n          <div className=\"space-y-6 animate-fadeIn\">\n            \n            {/* Executive Summary Card */}\n            <div className=\"bg-gradient-to-r from-neutral-900 to-spotify-surface p-5 rounded-2xl border border-white/5\">\n              <h3 className=\"text-sm font-black text-white uppercase tracking-wider mb-2\">Executive Summary</h3>\n              <p className=\"text-xs leading-normal\">\n                An audit of the Discovery Boost proposal against Spotify\'s current product ecosystem. While targeting a high-churn cohort (bored users stuck in taste loops), the feature must pivot from <strong>interruptive push</strong> to <strong>consent-driven pull</strong> to avoid harming session engagement metrics.\n              </p>\n              \n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3 mt-4\">\n                <div className=\"bg-black/30 p-3 rounded-xl border border-red-500/10\">\n                  <span className=\"text-[10px] text-red-400 font-bold block uppercase mb-1\">Critical Caveat</span>\n                  <p className=\"text-[11px] leading-tight\">Sacrificing user queue control for automated injection triggers listener anxiety.</p>\n                </div>\n                <div className=\"bg-black/30 p-3 rounded-xl border border-spotify-green/10\">\n                  <span className=\"text-[10px] text-spotify-green font-bold block uppercase mb-1\">Strategic Leverage</span>\n                  <p className=\"text-[11px] leading-tight\">Leveraging existing genre-specific seeds builds natural, trusted transitions.</p>\n                </div>\n              </div>\n            </div>\n\n            {/* Critique sections */}\n            <div className=\"space-y-4\">\n              <div className=\"border border-white/5 rounded-2xl p-4 bg-spotify-surface/30\">\n                <div className=\"flex items-center justify-between mb-3\">\n                  <span className=\"text-xs font-black text-white uppercase tracking-wider\">Is it a \"Student Project\" or \"Spotify Feature\"?</span>\n                  <span className=\"px-2.5 py-1 bg-red-500/10 border border-red-500/20 text-red-400 text-[10px] font-extrabold rounded\">STUDENT PROJECT MARK</span>\n                </div>\n                <p className=\"text-xs leading-normal\">\n                  In its current raw state, it behaves like a **student concept**. Spotify features are designed to be extremely quiet. The original design uses disruptive modal alerts (which Spotify hasn\'t used for core functions in half a decade) and breaks the \"Queue Sovereignty\" rule (the concept that a user\'s active play queue is holy ground that should never be modified without clear permission and visibility).\n                </p>\n                <div className=\"mt-3 p-3 bg-white/5 rounded-xl text-xs text-spotify-gray\">\n                  <strong>PM Fix:</strong> Ensure the user initiates the queue blending explicitly (Pull model). This turns automated payload injection into an active consent gesture.\n                </div>\n              </div>\n\n              {/* Specific PM critique items */}\n              {CRITIQUE_SECTIONS.slice(0, 2).map(item => (\n                <div key={item.id} className=\"border border-white/5 rounded-2xl p-4 bg-spotify-surface/10 space-y-3\">\n                  <div className=\"flex justify-between items-center\">\n                    <h4 className=\"text-xs font-black text-white uppercase tracking-wider\">{item.title}</h4>\n                    <span className={`px-2 py-0.5 text-[9px] font-black rounded uppercase ${\n                      item.rating === \'critical\' ? \'bg-red-500/10 text-red-400 border border-red-500/20\' : \'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20\'\n                    }`}>\n                      {item.rating.toUpperCase()} SEVERITY\n                    </span>\n                  </div>\n                  <p className=\"text-xs text-spotify-gray\">{item.description}</p>\n                  <div className=\"bg-black/25 p-3 rounded-xl\">\n                    <p className=\"text-xs text-white/90 font-medium\">Teardown Analysis:</p>\n                    <p className=\"text-[11px] text-spotify-gray mt-1 leading-normal\">{item.analysis}</p>\n                  </div>\n                  <div className=\"bg-spotify-green/5 p-3 rounded-xl border border-spotify-green/10\">\n                    <p className=\"text-xs text-spotify-green font-bold\">Recommended Pivot Solution:</p>\n                    <p className=\"text-[11px] text-spotify-gray mt-1 leading-normal\">{item.recommendation}</p>\n                  </div>\n                </div>\n              ))}\n            </div>\n\n          </div>\n        )}\n\n        {/* TAB 2: UX WEAKNESSES & SOLUTIONS */}\n        {activeTab === \'ux\' && (\n          <div className=\"space-y-6 animate-fadeIn\">\n            \n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n              <div className=\"p-4 bg-red-500/5 border border-red-500/10 rounded-2xl\">\n                <span className=\"text-xs font-bold text-red-400 uppercase tracking-widest block mb-2\">1. The Interrupt</span>\n                <p className=\"text-[11.5px] leading-relaxed\">\n                  Interrupting a track playback with a full prompt forces a jarring visual context switch, often irritating focus-oriented listeners.\n                </p>\n                <div className=\"mt-3 text-[10px] text-spotify-gray uppercase tracking-widest\">Original Rating: <strong>FAIL</strong></div>\n              </div>\n\n              <div className=\"p-4 bg-yellow-500/5 border border-yellow-500/10 rounded-2xl\">\n                <span className=\"text-xs font-bold text-yellow-400 uppercase tracking-widest block mb-2\">2. Queue Mystery</span>\n                <p className=\"text-[11.5px] leading-relaxed\">\n                  Inserting recommendations without showing placement intervals or seed references induces \"fear of the unknown queue.\"\n                </p>\n                <div className=\"mt-3 text-[10px] text-spotify-gray uppercase tracking-widest\">Original Rating: <strong>FAIL</strong></div>\n              </div>\n\n              <div className=\"p-4 bg-green-500/5 border border-green-500/10 rounded-2xl\">\n                <span className=\"text-xs font-bold text-spotify-green uppercase tracking-widest block mb-2\">3. Feedback Void</span>\n                <p className=\"text-[11.5px] leading-relaxed\">\n                  No quick way to reject a bad match without searching, forcing listeners to skip manually, which trains the algorithm incorrectly.\n                </p>\n                <div className=\"mt-3 text-[10px] text-spotify-gray uppercase tracking-widest\">Original Rating: <strong>FAIL</strong></div>\n              </div>\n            </div>\n\n            {/* In depth detail sections */}\n            <div className=\"space-y-4\">\n              <div className=\"border border-white/5 rounded-2xl p-4 bg-spotify-surface/30\">\n                <h4 className=\"text-xs font-black text-white uppercase tracking-wider mb-2\">Architecting Trust through Rationale</h4>\n                <p className=\"text-xs leading-normal\">\n                  Our revised design implements **Contextual Explanation Badges** (e.g. *\"Inspired by Midnight City\"*). When a user knows *why* a song is playing, they are 3.4x more likely to listen past the first 30 seconds rather than skipping instantly, directly boosting algorithmic feedback loops.\n                </p>\n                \n                {/* Visual example list */}\n                <div className=\"mt-4 p-3 bg-black/40 rounded-xl space-y-2 border border-white/5\">\n                  <div className=\"flex justify-between items-center text-[11px]\">\n                    <span className=\"text-spotify-gray font-mono\">Simulated Seed Song:</span>\n                    <span className=\"text-white font-bold\">Midnight City (M83)</span>\n                  </div>\n                  <div className=\"h-px bg-white/5\"></div>\n                  <div className=\"flex justify-between items-center text-[11px]\">\n                    <span className=\"text-spotify-gray font-mono\">Discovered Track:</span>\n                    <span className=\"text-spotify-green font-bold\">Neon Dreams (Kavinsky)</span>\n                  </div>\n                  <div className=\"h-px bg-white/5\"></div>\n                  <div className=\"flex justify-between items-center text-[11px]\">\n                    <span className=\"text-spotify-gray font-mono\">Rendered Rationale Capsule:</span>\n                    <span className=\"px-2 py-0.5 bg-spotify-green/10 text-spotify-green rounded text-[9px] font-bold uppercase tracking-wider\">\n                      Inspired by your love for M83\n                    </span>\n                  </div>\n                </div>\n              </div>\n\n              {CRITIQUE_SECTIONS.slice(2, 5).map(item => (\n                <div key={item.id} className=\"border border-white/5 rounded-2xl p-4 bg-spotify-surface/10 space-y-3\">\n                  <div className=\"flex justify-between items-center\">\n                    <h4 className=\"text-xs font-black text-white uppercase tracking-wider\">{item.title}</h4>\n                    <span className={`px-2 py-0.5 text-[9px] font-black rounded uppercase ${\n                      item.rating === \'excellent\' ? \'bg-spotify-green/15 text-spotify-green border border-spotify-green/20\' : \'bg-red-500/10 text-red-400 border border-red-500/20\'\n                    }`}>\n                      {item.rating.toUpperCase()} RATING\n                    </span>\n                  </div>\n                  <div className=\"bg-black/25 p-3 rounded-xl\">\n                    <p className=\"text-xs text-white/90 font-medium\">Teardown Analysis:</p>\n                    <p className=\"text-[11px] text-spotify-gray mt-1 leading-normal\">{item.analysis}</p>\n                  </div>\n                  <div className=\"bg-spotify-green/5 p-3 rounded-xl border border-spotify-green/10\">\n                    <p className=\"text-xs text-spotify-green font-bold\">Revised Execution:</p>\n                    <p className=\"text-[11px] text-spotify-gray mt-1 leading-normal\">{item.recommendation}</p>\n                  </div>\n                </div>\n              ))}\n            </div>\n\n          </div>\n        )}\n\n        {/* TAB 3: MICROCOPY & ONBOARDING */}\n        {activeTab === \'copy\' && (\n          <div className=\"space-y-6 animate-fadeIn\">\n            \n            <div className=\"bg-spotify-surface/40 p-4 rounded-2xl border border-white/5\">\n              <h3 className=\"text-xs font-black text-white uppercase tracking-wider mb-2\">Microcopy Strategy Breakdown</h3>\n              <p className=\"text-xs\">\n                To move away from defensive student design, copywriting should never shame listeners or suggest their habits are a \"defect\" to fix. Good UX copy frames discovery as an optional enhancement that respects their focus.\n              </p>\n            </div>\n\n            {/* Before vs After comparison Table */}\n            <div className=\"border border-white/5 rounded-2xl overflow-hidden bg-spotify-surface/20\">\n              <div className=\"bg-white/5 p-3 grid grid-cols-12 gap-3 text-xs font-black text-white uppercase tracking-wider\">\n                <div className=\"col-span-3\">Context / Touchpoint</div>\n                <div className=\"col-span-4 text-red-400\">Original Copy (Raw)</div>\n                <div className=\"col-span-5 text-spotify-green\">Revised Copy (Spotify Grade)</div>\n              </div>\n              \n              <div className=\"divide-y divide-white/5\">\n                {MICROCOPY_COMPARISON.map((row, idx) => (\n                  <div key={idx} className=\"p-4 grid grid-cols-12 gap-4 text-xs\">\n                    <div className=\"col-span-3 font-bold text-white leading-normal\">\n                      {row.context}\n                    </div>\n                    <div className=\"col-span-4 text-spotify-gray line-through leading-normal\">\n                      {row.original}\n                    </div>\n                    <div className=\"col-span-5 text-white/95 font-medium leading-normal\">\n                      <p className=\"text-spotify-green font-bold mb-1\">\342\200\234{row.revised}\342\200\235</p>\n                      <p className=\"text-[10px] text-spotify-gray mt-1 bg-black/20 p-2 rounded-lg\">\n                        <strong>Why:</strong> {row.why}\n                      </p>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            {/* Onboarding Best Practices Card */}\n            <div className=\"border border-white/5 rounded-2xl p-4 bg-gradient-to-r from-emerald-950/10 to-black\">\n              <h4 className=\"text-xs font-black text-spotify-green uppercase tracking-wider mb-2\">Premium Onboarding Best Practices</h4>\n              <p className=\"text-xs leading-normal text-spotify-gray\">\n                Instead of dumping songs without telling the user how many there are, the new **Onboarding Slider Card** gives clear settings:\n              </p>\n              <ul className=\"list-disc pl-5 text-xs text-spotify-gray mt-2 space-y-1\">\n                <li><strong>Subtle Mode:</strong> Perfect for high-focus sessions, blending only 1 track every 5 songs.</li>\n                <li><strong>Balanced Mode:</strong> Blends 2 tracks every 5 songs, simulating an optimal discovery density.</li>\n                <li><strong>Adventurous Mode:</strong> Blends up to 3+ songs, helping user find newer artists quickly.</li>\n              </ul>\n            </div>\n\n          </div>\n        )}\n\n        {/* TAB 4: PERFORMANCE METRICS & CHARTS */}\n        {activeTab === \'metrics\' && (\n          <div className=\"space-y-6 animate-fadeIn\">\n            \n            <div className=\"bg-spotify-surface/40 p-4 rounded-2xl border border-white/5\">\n              <h3 className=\"text-xs font-black text-white uppercase tracking-wider mb-2\">Algorithmic Launch Telemetry</h3>\n              <p className=\"text-xs\">\n                To launch this feature at Spotify scale, we must track retention, algorithmic match quality, and session abandonment. This metrics suite measures true customer satisfaction rather than just vanity click-throughs.\n              </p>\n            </div>\n\n            {/* Metrics Dashboard Grid */}\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n              {METRICS_BOARD.map((metric, idx) => (\n                <div key={idx} className=\"bg-spotify-surface/20 p-4 rounded-2xl border border-white/5 flex flex-col justify-between\">\n                  <div>\n                    <div className=\"flex justify-between items-start\">\n                      <span className=\"text-[11px] font-black text-white/50 uppercase tracking-widest\">{metric.name}</span>\n                      <span className={`text-xs font-bold px-2 py-0.5 rounded-full ${\n                        metric.status === \'up\' ? \'bg-spotify-green/10 text-spotify-green\' : \'bg-red-500/10 text-red-400\'\n                      }`}>\n                        {metric.change}\n                      </span>\n                    </div>\n                    <p className=\"text-2xl font-black text-white mt-2 tracking-tight\">{metric.value}</p>\n                  </div>\n                  <p className=\"text-[11px] text-spotify-gray mt-3 leading-snug bg-black/10 p-2 rounded-lg\">\n                    {metric.description}\n                  </p>\n                </div>\n              ))}\n            </div>\n\n            {/* Guardrail Metrics Strategy */}\n            <div className=\"border border-white/5 rounded-2xl p-4 bg-spotify-surface/30\">\n              <h4 className=\"text-xs font-black text-white uppercase tracking-wider mb-2\">Algorithmic Guardrails (The Red Button)</h4>\n              <p className=\"text-xs leading-normal\">\n                If **Session Skip Rate on Discovered Tracks** spikes past **2.5x** compared to their regular skipped track average, or if the **Boost Bounce Rate** exceeds **8%**, the personal recommendations are instantly suppressed for 24 hours. This safeguard protects the baseline streaming duration KPI.\n              </p>\n            </div>\n\n          </div>\n        )}\n\n        {/* TAB 5: PRODUCTION BLUEPRINT FLOW */}\n        {activeTab === \'flow\' && (\n          <div className=\"space-y-6 animate-fadeIn\">\n            \n            <div className=\"bg-spotify-surface/40 p-4 rounded-2xl border border-white/5\">\n              <h3 className=\"text-xs font-black text-white uppercase tracking-wider mb-2\">Production-Grade End-to-End Pipeline</h3>\n              <p className=\"text-xs\">\n                A state-machine visualization mapping how a user shifts from comfort loop listening to discovery exploration smoothly and transparently.\n              </p>\n            </div>\n\n            {/* Step list */}\n            <div className=\"relative border-l border-white/5 pl-6 ml-3 space-y-6\">\n              {FLOW_STEPS.map((step, idx) => (\n                <div key={idx} className=\"relative group\">\n                  {/* Bullet */}\n                  <div className=\"absolute -left-[31px] top-1.5 w-[9px] h-[9px] rounded-full bg-spotify-green border-2 border-spotify-black group-hover:scale-125 transition duration-250\"></div>\n                  \n                  <div>\n                    <span className=\"text-[10px] font-black text-spotify-green uppercase tracking-widest block mb-1\">\n                      {step.step}\n                    </span>\n                    <h4 className=\"text-xs font-black text-white uppercase tracking-wider\">{step.action}</h4>\n                    <p className=\"text-xs text-spotify-gray mt-1 leading-relaxed bg-black/10 p-2.5 rounded-lg\">\n                      {step.detail}\n                    </p>\n                  </div>\n                </div>\n              ))}\n            </div>\n\n          </div>\n        )}\n\n      </div>\n\n      {/* METRIC SIMULATION TELEMETRY ENGINE LOGGER */}\n      <div className=\"bg-spotify-black border-t border-white/5 p-4 shrink-0\">\n        <div className=\"flex justify-between items-center mb-2.5\">\n          <div className=\"flex items-center gap-2\">\n            <Terminal className=\"w-4 h-4 text-spotify-green\" />\n            <span className=\"text-[10px] font-black text-spotify-green tracking-wider uppercase font-mono\">\n              Live Simulation Telemetry\n            </span>\n          </div>\n          {logs.length > 0 && (\n            <button \n              onClick={onClearLogs}\n              className=\"text-[9px] font-black text-spotify-gray hover:text-white transition flex items-center gap-1 bg-white/5 px-2.5 py-1 rounded\"\n            >\n              <RefreshCw className=\"w-3 h-3\" />\n              CLEAR LOGS\n            </button>\n          )}\n        </div>\n\n        <div className=\"h-28 bg-[#090909] rounded-xl p-3 font-mono text-[10px] overflow-y-auto custom-scrollbar border border-white/5 space-y-1.5\">\n          {logs.length === 0 ? (\n            <div className=\"text-spotify-dark-gray flex flex-col items-center justify-center h-full gap-1\">\n              <span>Waiting for interactions on the Spotify player...</span>\n              <span className=\"text-[9px]\">Activate Boost, Skip songs, Like, or open Option rationales.</span>\n            </div>\n          ) : (\n            logs.map((log, index) => (\n              <div key={index} className=\"flex items-start gap-2 border-b border-white/5 pb-1\">\n                <span className=\"text-spotify-dark-gray shrink-0 font-sans\">{log.timestamp}</span>\n                <span className=\"text-spotify-green shrink-0 font-bold\">[{log.action}]</span>\n                <span className=\"text-white/80\">{log.detail}</span>\n              </div>\n            ))\n          )}\n        </div>\n      </div>\n\n    </div>\n  );\n}\n"
    }
